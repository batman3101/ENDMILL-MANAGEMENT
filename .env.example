# Supabase 연결 정보
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Supabase MCP 액세스 토큰 (Claude Code용)
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here

# 개발 환경 설정
NODE_ENV=development

# Realtime 킬스위치 (운영 레버)
# 'false'로 설정하면 모든 Supabase Realtime 구독이 비활성화된다.
# Realtime 재연결 폭주로 DB가 과부하될 때 즉시 부하를 끊기 위한 비상 스위치.
# (NEXT_PUBLIC_ 변수이므로 변경 후 재배포 필요. 미설정 시 기본값 = 활성화)
NEXT_PUBLIC_REALTIME_ENABLED=true

# 임시 인증 시스템 (개발용)
TEMP_AUTH_ENABLED=true
TEMP_ADMIN_EMAIL=your_admin_email@example.com
TEMP_ADMIN_PASSWORD=your_admin_password
TEMP_ADMIN_NAME=시스템 관리자
TEMP_ADMIN_DEPARTMENT=최고경영진
TEMP_ADMIN_POSITION=시스템 소유자
TEMP_ADMIN_ROLE=system_admin

# Google Gemini API 설정
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro

# AI 기능 설정
AI_RATE_LIMIT_PER_MINUTE=10
AI_CACHE_TTL_SECONDS=300
AI_MAX_TOKENS_INPUT=30000
AI_MAX_TOKENS_OUTPUT=8000
